{
  "manifest_version": 3,
  "name": "AURA Connect — LinkedIn Analytics",
  "version": "1.0.0",
  "description": "Sync your private LinkedIn analytics (views, impressions, demographics) to AURA Connect.",
  "permissions": ["activeTab", "storage", "cookies"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
